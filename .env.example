# 기상청 공공데이터포털 API 키 (단기예보)
KMA_API_KEY=your_kma_api_key_here

# 행안부 대피소 API 키 (무더위·한파쉼터)
SHELTER_API_KEY=your_shelter_api_key_here

# Google Gemini API 키
GEMINI_API_KEY=your_gemini_api_key_here

# Naver Dynamic Map API 키
NAVER_DYNAMICMAP_CLIENT_ID=your_naver_dynamicmap_client_id_here

# 통계청 KOSIS 공유서비스(Open API) 인증키 (지자체 대시보드 인구 통계 조회)
# https://kosis.kr/openapi 에서 발급 — 회원당 1개, 서비스ID/시크릿 구분 없음
KOSIS_API_KEY=your_kosis_api_key_here
